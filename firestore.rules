rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read profiles (leaderboard needs this)
      allow read: if request.auth != null;

      // Users can create and update their own profile freely.
      // NOTE: In Phase 2, these scores should be locked down to only be updatable by Cloud Functions.
      // For now, allow client-side updates so the app works standalone.
      allow update: if request.auth != null && request.auth.uid == userId;


      // Workouts sub-collection
      match /workouts/{workoutId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if false; // Immutable once logged
      }
    }

    // ── Leaderboards (written only by Cloud Functions) ─────────────────────
    match /leaderboards/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Pulse Feed ─────────────────────────────────────────────────────────
    match /feed/{postId} {
      allow read: if request.auth != null;
      allow create: if false; // Only Cloud Functions
      // Users can only add kudos
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).changedKeys().hasOnly(['kudos', 'kudos_from']);
      allow delete: if false;
    }
  }
}
